#include <stdio.h>

int nCr(int n, int r) {
    // Base Case 1: nCr is 1 if r is 0 or r is equal to n
    if (r == 0 || r == n) {
        return 1;
    }
    // Base Case 2: No combinations possible if r > n
    if (r > n) {
        return 0;
    }
    // Recursive Step: nCr = (n-1)C(r-1) + (n-1)Cr
    return nCr(n - 1, r - 1) + nCr(n - 1, r);
}

int main() {
    int n, r;

    printf("Enter values for n and r (n > r): ");
    if (scanf("%d %d", &n, &r) != 2) {
        printf("Invalid input.\n");
        return 1;
    }

    if (n < r || n < 0 || r < 0) {
        printf("Please ensure n >= r and both are positive.\n");
    } else {
        printf("The value of %dC%d is: %d\n", n, r, nCr(n, r));
    }

    return 0;
}
