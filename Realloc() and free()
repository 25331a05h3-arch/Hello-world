#include <stdio.h>
#include <stdlib.h>

int main() {
    int *arr;
        arr = (int*) malloc(3 * sizeof(int));
    for (int i = 0; i < 3; i++) arr[i] = (i + 1) * 10;

    int *temp = (int*) realloc(arr, 5 * sizeof(int));
    if (temp != NULL) {
        arr = temp;
        arr[3] = 40; arr[4] = 50;
    }

       free(arr);
    return 0;
}

