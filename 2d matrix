#include <stdio.h>

int main() {
    int rows, cols, i, j;
    int matrix[10][10]; 
    
    printf("Enter the number of rows and columns: ");
    scanf("%d %d", &rows, &cols);

   
    printf("Enter elements of the matrix:\n");
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            printf("Element [%d][%d]: ", i, j);
            scanf("%d", &matrix[i][j]);
        }
    }

    // 3. Print the 2D array in matrix form
    printf("\nThe Matrix is:\n");
    for (i = 0; i < rows; i++) {
        for (j = 0; j < cols; j++) {
            // Use \t for even spacing between columns
            printf("%d\t", matrix[i][j]);
        }
       
        printf("\n");
    }

    return 0;
}

