#include <stdio.h>

int main() {
  
    int data[5] = {10, 20, 30, 40, 50};
    
   
    int *ptr = data;

    printf("Accessing array elements using pointers:\n");

       for (int i = 0; i < 5; i++) {
        // *(ptr + i) is equivalent to data[i]
        printf("Element at index %d = %d\n", i, *(ptr + i));
    }

    return 0;
}
