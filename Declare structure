#include <stdio.h>
#include <string.h> 
struct Student {
    int rollNumber;
    char name[50];
    float marks;
};

int main() {
    struct Student s1;
    s1.rollNumber = 101;
    s1.marks = 88.5;
    strcpy(s1.name, "Alice Johnson");

    printf("--- Student Details ---\n");
    printf("Roll Number: %d\n", s1.rollNumber);
    printf("Name:%s\n", s1.name);
    printf("Marks:%.2f\n", s1.marks);
    return 0;
}
