#include <stdio.h>
#include <stdlib.h>
int main() {
    int n, i, *ptr_m, *ptr_c;

    printf("Enter number of elements: ");
    scanf("%d", &n);

      ptr_m = (int*) malloc(n * sizeof(int));

    
    ptr_c = (int*) calloc(n, sizeof(int));

    l
    if (ptr_m == NULL || ptr_c == NULL) {
        printf("Memory allocation failed!\n");
        return 1;
    }

    printf("\nMemory successfully allocated.\n");

  
    printf("malloc array elements (manual assignment): ");
    for (i = 0; i < n; ++i) {
        ptr_m[i] = i + 1; 
        printf("%d ", ptr_m[i]);
    }

       printf("\ncalloc array elements (initial values): ");
    for (i = 0; i < n; ++i) {
        printf("%d ", ptr_c[i]);
    }

    
    free(ptr_m);
    free(ptr_c);

       ptr_m = NULL;
    ptr_c = NULL;

    return 0;
}

